# PostgreSQL
POSTGRES_USER=devshort
POSTGRES_PASSWORD=devshort_pass
POSTGRES_DB=devshort

# Database connection (internal Docker hostname)
DATABASE_URL=postgresql://devshort:devshort_pass@postgres:5432/devshort

# Backend
PORT=4000
NODE_ENV=development
SHORT_CODE_LENGTH=8
BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# Grafana (Monitoring)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
