# AIOps Platform Backend
APP_NAME="AIOps Platform API"
APP_VERSION="0.1.0"
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api/v1

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
REQUEST_ID_HEADER=X-Request-ID

# Security
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=aiops-platform
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8

# CORS
CORS_ORIGINS='["http://localhost:5173", "http://localhost:3000"]'

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://aiops:aiops@localhost:5433/aiops
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
SQL_ECHO=false
